generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReadingQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_NOT_GIVEN
  MATCHING_HEADING
  MATCHING_INFORMATION
  MATCHING_FEATURES
  MATCHING_SENTENCE_ENDINGS
  SENTENCE_COMPLETION
  SUMMARY_COMPLETION
  NOTE_COMPLETION
  TABLE_COMPLETION
  FLOW_CHART_COMPLETION
  DIAGRAM_LABELLING
  SHORT_ANSWER
}

enum ListeningQuestionType {
  MULTIPLE_CHOICE
  FORM_COMPLETION
  NOTE_COMPLETION
  TABLE_COMPLETION
  SUMMARY_COMPLETION
  SENTENCE_COMPLETION
  MATCHING
  MAP_LABELLING
  SHORT_ANSWER
}

enum ListeningIconStyle {
  headphones
  broadcast
  microphone
}

enum ListeningAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum SpeakingCategory {
  MOCK
  PART_1
  PART_2
  PART_3
}

enum SpeakingAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum SpeakingEvaluationMode {
  BASIC
  AI
}

enum WritingCategory {
  MOCK
  TASK_1
  TASK_2
}

enum WritingTask1Type {
  GRAPH
  CHART
  TABLE
  MAP
  PROCESS
  DIAGRAM
  PIE
}

enum WritingAttemptStatus {
  DRAFT
  PENDING_ANALYSIS
}

enum ReadingAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  // Profile photos are stored as a validated data URL for now. Keeping this
  // nullable lets an account fall back to its initials after a photo is removed.
  image     String?  @db.Text

  readingAttempts   ReadingAttempt[]
  readingResults    ReadingResult[]
  listeningAttempts ListeningAttempt[]
  listeningResults  ListeningResult[]
  writingAttempts   WritingAttempt[]
  speakingAttempts  SpeakingAttempt[]
  speakingResults   SpeakingResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpeakingTest {
  id          String           @id @default(cuid())
  title       String
  category    SpeakingCategory
  isPublished Boolean          @default(false)

  parts    SpeakingPart[]
  attempts SpeakingAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpeakingPart {
  id         String @id @default(cuid())
  testId     String
  partNumber Int

  cueCardTitle       String?
  cueCardDescription String? @db.Text
  bulletPoints       String[] @default([])
  closingQuestion    String? @db.Text
  preparationMinutes Int @default(1)
  speakingMinutes    Int @default(2)
  durationMinutes    Int @default(5)
  topic              String?

  questions SpeakingQuestion[]
  test      SpeakingTest       @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([testId, partNumber])
}

model SpeakingQuestion {
  id             String @id @default(cuid())
  partId         String
  questionNumber Int
  text           String @db.Text

  part SpeakingPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, questionNumber])
}

model SpeakingAttempt {
  id         String                @id @default(cuid())
  userId     String
  testId     String
  status     SpeakingAttemptStatus @default(IN_PROGRESS)
  recordings Json
  startedAt  DateTime              @default(now())
  submittedAt DateTime?
  updatedAt DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  test   SpeakingTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  result SpeakingResult?

  @@index([userId, updatedAt])
  @@index([testId])
}

model SpeakingResult {
  id                   String                 @id @default(cuid())
  attemptId            String                 @unique
  userId               String
  recordingCount       Int
  totalQuestions       Int
  totalDurationSeconds Int
  completionPercentage Float
  basicScore           Float
  estimatedBandScore   Float
  evaluationMode       SpeakingEvaluationMode @default(BASIC)
  algorithmVersion     String                 @default("basic-v1")
  feedback             Json?
  createdAt            DateTime               @default(now())

  attempt SpeakingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReadingMockTest {
  id             String   @id @default(cuid())

  title          String
  tags           String[]

  duration       Int      @default(60)
  totalQuestions Int      @default(40)

  isPublished    Boolean  @default(false)

  passages       ReadingPassage[]
  attempts       ReadingAttempt[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ReadingPassage {
  id             String   @id @default(cuid())

  mockTestId     String

  passageNumber  Int

  title          String

  instruction    String?

  passageText    String   @db.Text

  imageUrl       String?

  questions      ReadingQuestion[]

  mockTest ReadingMockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mockTestId, passageNumber])
}

model ReadingQuestion {
  id             String   @id @default(cuid())

  passageId      String

  questionNumber Int

  type           ReadingQuestionType

  questionText   String   @db.Text

  options        Json?

  correctAnswer  String[]

  marks          Int      @default(1)

  explanation    String?  @db.Text

  passage ReadingPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([passageId, questionNumber])
}

model ReadingAttempt {
  id          String               @id @default(cuid())
  userId      String
  mockTestId  String
  status      ReadingAttemptStatus @default(IN_PROGRESS)
  // Stored as { [readingQuestionId]: answer } to match the frontend session
  // state and support autosaving individual answers.
  answers     Json
  startedAt   DateTime             @default(now())
  submittedAt DateTime?
  updatedAt   DateTime             @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockTest ReadingMockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
  result   ReadingResult?

  @@index([userId, updatedAt])
  @@index([mockTestId])
}

model ReadingResult {
  id               String   @id @default(cuid())
  attemptId        String   @unique
  userId           String
  correctAnswers   Int
  totalQuestions   Int
  rawScore         Int
  totalMarks       Int
  percentage       Float
  // This is a deliberately simple provisional estimate. A future scoring
  // engine can replace it while retaining the attempt and answer history.
  bandScore        Float
  algorithmVersion String   @default("basic-v1")
  createdAt        DateTime @default(now())

  attempt ReadingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ListeningMockTest {
  id String @id @default(cuid())

  title          String
  iconStyle      ListeningIconStyle @default(headphones)
  totalQuestions Int                @default(40)
  totalMinutes   Int                @default(32)
  bufferSeconds  Int                @default(30)
  isPublished    Boolean            @default(false)

  parts ListeningPart[]
  attempts ListeningAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ListeningPart {
  id                   String  @id @default(cuid())
  mockTestId           String
  partNumber           Int
  title                String
  instruction          String  @db.Text
  transcript           String? @db.Text
  audioStorageKey      String?
  audioUrl             String? @db.Text
  audioDurationSeconds Int
  mapImageUrl          String? @db.Text
  mapImageAlt          String?

  questions ListeningQuestion[]
  mockTest  ListeningMockTest   @relation(fields: [mockTestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mockTestId, partNumber])
}

model ListeningQuestion {
  id             String                @id @default(cuid())
  partId         String
  questionNumber Int
  type           ListeningQuestionType
  questionText   String                @db.Text
  options        String[]              @default([])
  correctAnswer  String                @db.Text
  marks          Int                   @default(1)
  explanation    String?               @db.Text

  part ListeningPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, questionNumber])
}

model ListeningAttempt {
  id          String                 @id @default(cuid())
  userId      String
  mockTestId  String
  status      ListeningAttemptStatus @default(IN_PROGRESS)
  // Map of ListeningQuestion ID to the answer currently entered by the learner.
  answers     Json
  startedAt   DateTime               @default(now())
  submittedAt DateTime?
  updatedAt   DateTime               @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockTest ListeningMockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
  result   ListeningResult?

  @@index([userId, updatedAt])
  @@index([mockTestId])
}

model ListeningResult {
  id               String   @id @default(cuid())
  attemptId        String   @unique
  userId           String
  correctAnswers   Int
  totalQuestions   Int
  rawScore         Int
  totalMarks       Int
  percentage       Float
  // Deliberately provisional. A future IELTS scoring engine can replace it
  // without losing completed attempts or answer history.
  bandScore        Float
  algorithmVersion String   @default("basic-v1")
  createdAt        DateTime @default(now())

  attempt ListeningAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model WritingTest {
  id          String          @id @default(cuid())
  title       String
  category    WritingCategory
  isPublished Boolean         @default(false)

  tasks WritingTask[]
  attempts WritingAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WritingTask {
  id        String @id @default(cuid())
  testId    String
  taskNumber Int
  title     String
  prompt    String @db.Text
  typeLabel String?
  task1Type WritingTask1Type?
  // The current admin form stores image data URLs, so use TEXT rather than a
  // short varchar-compatible column.
  imageUrl String? @db.Text
  imageAlt String?

  test WritingTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  essays WritingEssay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([testId, taskNumber])
}

model WritingAttempt {
  id          String               @id @default(cuid())
  userId      String
  testId      String
  status      WritingAttemptStatus @default(DRAFT)
  startedAt   DateTime             @default(now())
  submittedAt DateTime?
  updatedAt   DateTime             @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  test    WritingTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  essays  WritingEssay[]

  @@index([userId, updatedAt])
  @@index([testId])
}

model WritingEssay {
  id        String   @id @default(cuid())
  attemptId String
  taskId    String
  content   String   @db.Text
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempt WritingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  task    WritingTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([attemptId, taskId])
  @@index([taskId])
}
