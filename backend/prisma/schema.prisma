generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReadingQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_NOT_GIVEN
  MATCHING_HEADING
  MATCHING_INFORMATION
  MATCHING_FEATURES
  MATCHING_SENTENCE_ENDINGS
  SENTENCE_COMPLETION
  SUMMARY_COMPLETION
  NOTE_COMPLETION
  TABLE_COMPLETION
  FLOW_CHART_COMPLETION
  DIAGRAM_LABELLING
  SHORT_ANSWER
}

enum ListeningQuestionType {
  MULTIPLE_CHOICE
  FORM_COMPLETION
  NOTE_COMPLETION
  TABLE_COMPLETION
  SUMMARY_COMPLETION
  SENTENCE_COMPLETION
  MATCHING
  MAP_LABELLING
  SHORT_ANSWER
}

enum ListeningIconStyle {
  headphones
  broadcast
  microphone
}

enum SpeakingCategory {
  MOCK
  PART_1
  PART_2
  PART_3
}

enum SpeakingAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum SpeakingEvaluationMode {
  BASIC
  AI
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(USER)

  speakingAttempts SpeakingAttempt[]
  speakingResults  SpeakingResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpeakingTest {
  id          String           @id @default(cuid())
  title       String
  category    SpeakingCategory
  isPublished Boolean          @default(false)

  parts    SpeakingPart[]
  attempts SpeakingAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpeakingPart {
  id         String @id @default(cuid())
  testId     String
  partNumber Int

  cueCardTitle       String?
  cueCardDescription String? @db.Text
  bulletPoints       String[] @default([])
  closingQuestion    String? @db.Text
  preparationMinutes Int @default(1)
  speakingMinutes    Int @default(2)
  durationMinutes    Int @default(5)
  topic              String?

  questions SpeakingQuestion[]
  test      SpeakingTest       @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([testId, partNumber])
}

model SpeakingQuestion {
  id             String @id @default(cuid())
  partId         String
  questionNumber Int
  text           String @db.Text

  part SpeakingPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, questionNumber])
}

model SpeakingAttempt {
  id         String                @id @default(cuid())
  userId     String
  testId     String
  status     SpeakingAttemptStatus @default(IN_PROGRESS)
  recordings Json
  startedAt  DateTime              @default(now())
  submittedAt DateTime?
  updatedAt DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  test   SpeakingTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  result SpeakingResult?

  @@index([userId, updatedAt])
  @@index([testId])
}

model SpeakingResult {
  id                   String                 @id @default(cuid())
  attemptId            String                 @unique
  userId               String
  recordingCount       Int
  totalQuestions       Int
  totalDurationSeconds Int
  completionPercentage Float
  basicScore           Float
  estimatedBandScore   Float
  evaluationMode       SpeakingEvaluationMode @default(BASIC)
  algorithmVersion     String                 @default("basic-v1")
  feedback             Json?
  createdAt            DateTime               @default(now())

  attempt SpeakingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReadingMockTest {
  id             String   @id @default(cuid())

  title          String
  tags           String[]

  duration       Int      @default(60)
  totalQuestions Int      @default(40)

  isPublished    Boolean  @default(false)

  passages       ReadingPassage[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ReadingPassage {
  id             String   @id @default(cuid())

  mockTestId     String

  passageNumber  Int

  title          String

  instruction    String?

  passageText    String   @db.Text

  imageUrl       String?

  questions      ReadingQuestion[]

  mockTest ReadingMockTest @relation(fields: [mockTestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mockTestId, passageNumber])
}

model ReadingQuestion {
  id             String   @id @default(cuid())

  passageId      String

  questionNumber Int

  type           ReadingQuestionType

  questionText   String   @db.Text

  options        Json?

  correctAnswer  String[]

  marks          Int      @default(1)

  explanation    String?  @db.Text

  passage ReadingPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([passageId, questionNumber])
}

model ListeningMockTest {
  id String @id @default(cuid())

  title          String
  iconStyle      ListeningIconStyle @default(headphones)
  totalQuestions Int                @default(40)
  totalMinutes   Int                @default(32)
  bufferSeconds  Int                @default(30)
  isPublished    Boolean            @default(false)

  parts ListeningPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ListeningPart {
  id                   String  @id @default(cuid())
  mockTestId           String
  partNumber           Int
  title                String
  instruction          String  @db.Text
  transcript           String? @db.Text
  audioStorageKey      String?
  audioUrl             String? @db.Text
  audioDurationSeconds Int
  mapImageUrl          String? @db.Text
  mapImageAlt          String?

  questions ListeningQuestion[]
  mockTest  ListeningMockTest   @relation(fields: [mockTestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mockTestId, partNumber])
}

model ListeningQuestion {
  id             String                @id @default(cuid())
  partId         String
  questionNumber Int
  type           ListeningQuestionType
  questionText   String                @db.Text
  options        String[]              @default([])
  correctAnswer  String                @db.Text
  marks          Int                   @default(1)
  explanation    String?               @db.Text

  part ListeningPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, questionNumber])
}
